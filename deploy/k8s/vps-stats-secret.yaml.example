# Copy to vps-stats-secret.yaml, set a real token, then apply.
# Keep the real file out of git — `deploy/k8s/*secret.yaml` is gitignored.
#
# Create from the CLI instead if you prefer:
#   kubectl -n aiops create secret generic vps-stats-secret \
#     --from-literal=VPS_STATS_TOKEN="$(openssl rand -hex 32)"

apiVersion: v1
kind: Secret
metadata:
  name: vps-stats-secret
  namespace: aiops
type: Opaque
stringData:
  VPS_STATS_TOKEN: REPLACE_WITH_A_LONG_RANDOM_STRING
