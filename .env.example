APP_NAME=Personal AI Ops Platform
APP_ENV=development
APP_HOST=0.0.0.0
API_PORT=8000
TIMEZONE=Asia/Kuala_Lumpur

DATABASE_URL=sqlite:////data/ai_ops.db
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
DEFAULT_REPORT_CHAT_ID=

OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_MODELS=qwen2.5:3b,qwen2.5-coder:7b,gemma2:2b
OLLAMA_REQUEST_TIMEOUT=180

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

LLM_TEMPERATURE=0.2
MEMORY_WINDOW=12
SYSTEM_PROMPT=You are my personal AI operations brain. Help me manage tasks, reason clearly, and coordinate my device agents safely.

AGENT_BASIC_AUTH_USERNAME=agent
AGENT_API_SHARED_KEY=change-me-now
AGENT_HEARTBEAT_TTL_SECONDS=120
HEALTH_REPORT_INTERVAL_SECONDS=600
DAILY_REPORT_CRON=0 8 * * *

FLOWER_PORT=5555
OLLAMA_PORT=11434
REDIS_PORT=6379
N8N_PORT=5678
N8N_ENCRYPTION_KEY=replace-with-a-long-random-string
N8N_HOST=your-vps-ip-or-domain
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-this-n8n-password
